{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-close",
    "opener:default",
    "fs:allow-read-dir",
    "fs:allow-exists",
    "fs:allow-read-file",
    "fs:allow-read-text-file",
    {
      "identifier": "fs:scope",
      "allow": [
        "$HOME/**",
        "$DESKTOP/**",
        "$DOCUMENT/**",
        "$DOWNLOAD/**",
        "$PICTURE/**",
        "$VIDEO/**",
        "$AUDIO/**",
        "C:/**",
        "D:/**",
        "E:/**",
        "F:/**"
      ]
    }
  ]
}
